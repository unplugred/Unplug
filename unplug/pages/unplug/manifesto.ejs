<%- include('../partials/header',{title:"manifesto",ogimage:assets+"/manifesto/og.jpg",css:false}) %>
		<style>
			body {
				background: white;
				margin: 0;
				padding: 0;
				overflow-x: clip;
				line-height: 0;
				font-size: 0;
			}
			img {
				max-width: 100vw;
				pointer-events: none;
				display: block;
			}
			a:hover {
				opacity: .6;
			}
			#ci {
				--bgx: 60%;
				--bgy: 90%;
				width: 80vw;
				height: calc(80vh - 13vw);
				background-size: cover;
				background-position: var(--bgx) var(--bgy);
				background-image: url("<%= assets %>/manifesto/ci.jpg");
			}
			@media screen and (max-aspect-ratio:0.9) {
				#ci {
					background: none;
				}
				#ci::after {
					content: "";
					width: calc(80vh - 13vw);
					height: 80vw;
					transform: rotate(-90deg) translateX(-100%);
					transform-origin: top left;
					background-size: cover;
					background-position: var(--bgx) var(--bgy);
					background-image: url("<%= assets %>/manifesto/ci.jpg");
					display: block;
					position: absolute;
				}
			}
			#ct {
				width: 80vw;
				margin: 10vh 0 0 0;
			}
			#cf {
				width: 80vw;
				margin: 0 0 3.5vh 0;
			}
			#dl {
				display: flex;
				justify-content: space-between;
				width: 80vw;
				margin: 0 0 4vh 0;
			}
			.dl {
				display: inline-block;
			}
			.dl img, img.dl {
				height: min(1.25vh, 1.667vw);
				margin: 1vw 0;
			}
			.t {
				width: min(60vh, 80vw);
			}
			.r {
				margin-right: calc(min(min(60vh, 80vw), 80vw - min(80vh, 80vw)));
			}
			.l {
				margin-left: calc(min(min(60vh, 80vw), 80vw - min(80vh, 80vw)));
			}
			div.t, .i {
				height: calc(max(min(60vh, 80vw), min(84vh, 112vw) - 60vw + min(80vh, 60vw)));
				margin-top: 5vw;
				background-repeat: no-repeat;
				background-size: contain;
			}
			div.t {
				background-position: bottom;
			}
			.i {
				width: min(60vh, 80vw);
				margin-bottom: min(30vh, 40vw);
			}
			#i {
				position: fixed;
				z-index: -1;
				width: 100vw;
			}
			#at { background-image: url("<%= assets %>/manifesto/1t.svg"); }
			#ai { background-image: url("<%= assets %>/manifesto/1i.png"); }
			#bt { background-image: url("<%= assets %>/manifesto/2t.svg"); }
			#bi { background-image: url("<%= assets %>/manifesto/2i.png"); }
			#dt { background-image: url("<%= assets %>/manifesto/3t.svg"); }
			#di { background-image: url("<%= assets %>/manifesto/3i.png"); }
			#et { background-image: url("<%= assets %>/manifesto/4t.svg"); }
			#ei { background-image: url("<%= assets %>/manifesto/4i.png"); }
			#gt { background-image: url("<%= assets %>/manifesto/5t.svg"); }
			#gi { background-image: url("<%= assets %>/manifesto/5i.png"); }
			#ht { background-image: url("<%= assets %>/manifesto/6t.svg"); }
			#hi { background-image: url("<%= assets %>/manifesto/6i.png"); }
			#fi {
				margin-top: 10vw;
				height: min(14.475vh, 19.3vw);
				margin-bottom: max(-14.475vh, -19.3vw);
				margin-left: min(44.25vh, 59vw);
			}
			#ft {
				display: block;
				width: min(60vh, 80vw);
			}
			#fm {
				margin-bottom: 5vw;
			}
		</style>
	</head>
	<body>
		<center>
			<img id="ct" src="<%= assets %>/manifesto/ct.svg" />
			<div id="ci"></div>
			<img id="cf" src="<%= assets %>/manifesto/cf.svg" />
			<div id="dl">
				<img id="dl0" class="dl"                                               src="<%= assets %>/manifesto/dl.svg"     />
				<a   id="dl1" class="dl" target="_blank" href="/manifesto/pdf"   ><img src="<%= assets %>/manifesto/pdf.svg"    /></a>
				<a   id="dl2" class="dl" target="_blank" href="/manifesto/zine"  ><img src="<%= assets %>/manifesto/zine.svg"   /></a>
				<a   id="dl3" class="dl" target="_blank" href="/manifesto/poster"><img src="<%= assets %>/manifesto/poster.svg" /></a>
			</div>
			<img id="it" class="t" src="<%= assets %>/manifesto/it.svg" />
			<div id="i">
				<div id="ai" class="i l"></div>
				<div id="bi" class="i r"></div>
				<div id="di" class="i l"></div>
				<div id="ei" class="i r"></div>
				<div id="gi" class="i l"></div>
				<div id="hi" class="i r"></div>
			</div>
			<div id="t">
				<div id="at" class="t r"></div>
				<div id="bt" class="t l"></div>
				<div id="dt" class="t r"></div>
				<div id="et" class="t l"></div>
				<div id="gt" class="t r"></div>
				<div id="ht" class="t l"></div>
			</div>
			<a id="ft" href="https://unplug.red">
				<img id="fi" src="<%= assets %>/manifesto/fi.png" />
				<img class="t" src="<%= assets %>/manifesto/ft.svg" />
			</a>
			<div id="fm"></div>
		</center>
		<script>
			var scrollspeed = 0.0002;
			var parallax = .35;

			var scroll = 0;
			var scrollprelerp = 0;
			var diff = 0;

			window.onload = function(){
				scrollprelerp = document.documentElement.scrollTop;
				scroll = scrollprelerp;
				draw();
				window.requestAnimationFrame(update);
			};
			window.onresize = draw;

			var dt = null;
			function update(timestamp) {
				if(!dt) dt = timestamp;
				let dtt = Math.min(1,scrollspeed*(timestamp-dt));
				dt = timestamp;

				diff = scroll;
				scrollprelerp = document.documentElement.scrollTop;
				let difff = scrollprelerp-scroll;
				scroll = Math.max(Math.min(scrollprelerp,scroll),Math.min(Math.max(scrollprelerp,scroll),scroll+difff*difff*(difff>0?1:-1)*dtt));
				diff -= scroll;
				if(Math.abs(diff*parallax) > .1) draw();

				requestAnimationFrame(update);
			}

			var ci = document.getElementById("ci");
			var i = document.getElementById("i");
			var it = document.getElementById("it");
			var t = document.getElementById("t");
			function draw() {
				ci.style.setProperty('--bgx',Math.min(100,Math.max(0,(scroll/window.innerHeight-.5)*20+35))+"%");
				ci.style.setProperty('--bgy',Math.min(100,Math.max(0,(scroll/window.innerHeight-.5)*-50+70))+"%");
				i.style.top = (it.offsetTop+it.offsetHeight-scroll)*(i.offsetHeight/t.offsetHeight)+"px";
			}
		</script>
<%- include('../partials/footer') %>
